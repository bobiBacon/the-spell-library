{
	"schemaVersion": 1,
	"id": "the-spell-library",
	"version": "${version}",
	"custom": {
		"cardinal-components": [
			"the-spell-library:schools_mana",
			"the-spell-library:mana_regen",
			"the-spell-library:cooldown_speed",
			"the-spell-library:spell_power",
			"the-spell-library:cast_speed"
		]
	},
	"name": "The Spell Library",
	"description": "A code-driven library that provides developer-friendly utilities. It serves as a solid foundation for creating highly customizable spells and rituals.",
	"authors": [
		"bob_bacon"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/the-spell-library/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.bobbacon.TheSpellLibrary"
		],
		"client": [
			"net.bobbacon.TheSpellLibraryClient"
		],
		"cardinal-components": [
			"net.bobbacon.components.ModComponents"
		]
		${datagenEntrypoint}


},
	"mixins": [
		"the-spell-library.mixins.json",
		{
			"config": "the-spell-library.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"registry-helper-lib": "*",
		"cardinal-components-base": "*",
		"cardinal-components-entity": "*"
	}
}